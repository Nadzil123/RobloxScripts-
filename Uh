    LMG2L["NotificationText_7"]["Size"] = UDim2.new(1, -40, 1, -48);
    LMG2L["NotificationText_7"]["Text"] = [[This is an example notification with improved UI design. It supports multiple lines and looks modern!]];
    LMG2L["NotificationText_7"]["Name"] = [[NotificationText]];
    LMG2L["NotificationText_7"]["Position"] = UDim2.new(0, 20, 0, 43);
    LMG2L["NotificationText_7"]["TextTransparency"] = 0;  -- ✅ Visible
    LMG2L["NotificationText_7"]["BackgroundTransparency"] = 1;

    LMG2L["UICorner_8"] = Instance.new("UICorner", LMG2L["NotificationText_7"]);
    LMG2L["UICorner_8"]["CornerRadius"] = UDim.new(0, 6);

    local uiScale = Instance.new("UIScale", LMG2L["Frame_2"])
    uiScale.Scale = 1  -- ✅ Full size visible

    notificationData.Frame = LMG2L["Frame_2"]

    local function closeNotification(reason)
        if isClosing then return end
        isClosing = true
        notificationData.IsAlive = false
        closeReason = reason or "unknown"
        
        local callbackData = {
            Reason = closeReason,
            NotificationId = notificationData.Id,
            Title = notificationData.Title,
            Text = notificationData.Text,
            CreatedAt = notificationData.CreatedAt,
            ClosedAt = tick(),
            LifeTime = tick() - notificationData.CreatedAt,
            WasManualClose = (closeReason == "user"),
            WasAutoClose = (closeReason == "expired"),
            WasRemovedByLimit = (closeReason == "max_exceeded")
        }
        
        local fadeTime = 0.4
        local slideDistance = 70
        local scaleTarget = 0.7
        
        local scaleTween = Cleanup:AddTween(TweenService:Create(uiScale, TweenInfo.new(fadeTime, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Scale = scaleTarget
        }))
        scaleTween:Play()
        
        local currentPos = LMG2L["Frame_2"].Position
        local slideTween = Cleanup:AddTween(TweenService:Create(LMG2L["Frame_2"], TweenInfo.new(fadeTime, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, slideDistance, currentPos.Y.Scale, currentPos.Y.Offset),
            BackgroundTransparency = 1
        }))
        slideTween:Play()
        
        for _, child in pairs(LMG2L["Frame_2"]:GetDescendants()) do
            if child:IsA("TextLabel") then
                local tween = Cleanup:AddTween(TweenService:Create(child, TweenInfo.new(fadeTime), {
                    TextTransparency = 1,
                    BackgroundTransparency = 1
                }))
                tween:Play()
            elseif child:IsA("TextButton") then
                local tween = Cleanup:AddTween(TweenService:Create(child, TweenInfo.new(fadeTime), {
                    TextTransparency = 1,
                    BackgroundTransparency = 1
                }))
                tween:Play()
            elseif child:IsA("Frame") then
                local tween = Cleanup:AddTween(TweenService:Create(child, TweenInfo.new(fadeTime), {
                    BackgroundTransparency = 1
                }))
                tween:Play()
            elseif child:IsA("ImageLabel") then
                local tween = Cleanup:AddTween(TweenService:Create(child, TweenInfo.new(fadeTime), {
                    ImageTransparency = 1
                }))
                tween:Play()
            end
        end
        
        for i, notif in ipairs(ActiveNotifications) do
            if notif == notificationData then
                table.remove(ActiveNotifications, i)
                break
            end
        end
        
        RepositionAllNotifications(notificationData, false)
        
        task.wait(fadeTime)
        
        Cleanup:Destroy()
        
        if LMG2L["Frame_2"] and LMG2L["Frame_2"].Parent then
            LMG2L["Frame_2"]:Destroy()
        end
        
        task.spawn(function()
            if closeReason == "user" and config.OnUserClose then
                pcall(config.OnUserClose, callbackData)
            elseif closeReason == "expired" and config.OnExpire then
                pcall(config.OnExpire, callbackData)
            elseif closeReason == "max_exceeded" and config.OnMaxExceeded then
                pcall(config.OnMaxExceeded, callbackData)
            end
            
            if config.OnClose then
                pcall(config.OnClose, callbackData)
            end
        end)
    end

    Cleanup:AddConnection(LMG2L["TextButton_6"].MouseButton1Click:Connect(function()
        closeNotification("user")
    end))

    Cleanup:AddConnection(LMG2L["TextButton_6"].MouseEnter:Connect(function()
        if not isClosing then
            local hoverTween = Cleanup:AddTween(TweenService:Create(LMG2L["TextButton_6"], TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(255, 80, 80),
                Size = UDim2.new(0, 30, 0, 30)
            }))
            hoverTween:Play()
        end
    end))

    Cleanup:AddConnection(LMG2L["TextButton_6"].MouseLeave:Connect(function()
        if not isClosing then
            local leaveTween = Cleanup:AddTween(TweenService:Create(LMG2L["TextButton_6"], TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(255, 60, 60),
                Size = UDim2.new(0, 28, 0, 28)
            }))
            leaveTween:Play()
        end
    end))

    if config.Text then
        LMG2L["NotificationText_7"].Text = config.Text
    end
    
    if config.Title then
        LMG2L["NotificationLabel_4"].Text = "  " .. config.Title
    end
    
    if config.BarColor then
        LMG2L["ProgressBar_12"].BackgroundColor3 = config.BarColor
    end
    
    local duration = config.Duration or 5
    
    if duration <= 0 then
        duration = 5
    end
    
    table.insert(ActiveNotifications, notificationData)
    
    while #ActiveNotifications > MaxNotifications do
        local oldest = ActiveNotifications[1]
        if oldest and oldest.Frame then
            oldest.Frame:Destroy()
        end
        table.remove(ActiveNotifications, 1)
    end
    
    -- ✅ Calculate position for this notif
    local yOffset = 0
    for i = #ActiveNotifications, 1, -1 do
        local notif = ActiveNotifications[i]
        if notif ~= notificationData and notif.Height then
            yOffset = yOffset + notif.Height + 15
        end
    end
    
    -- ✅ Set initial position (offscreen right, correct Y)
    LMG2L["Frame_2"].Position = UDim2.new(1, 350, 1, -(yOffset + finalHeight))
    
    -- Reposition others
    RepositionAllNotifications(notificationData, false)
    
    task.wait(0.05)
    
    -- ✅ Slide in to final position
    local finalPos = UDim2.new(1, 0, 1, -(yOffset + finalHeight))
    local slideIn = Cleanup:AddTween(TweenService:Create(LMG2L["Frame_2"], TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = finalPos
    }))
    slideIn:Play()

    local timerThread = coroutine.create(function()
        local startTime = tick()

        while not isClosing do
            local elapsed = tick() - startTime
            local progress = 1 - (elapsed / duration)

            if progress <= 0 then
                LMG2L["ProgressBar_12"].Size = UDim2.new(0, 0, 1, 0)
                break
            end

            LMG2L["ProgressBar_12"].Size = UDim2.new(progress, 0, 1, 0)
            task.wait(0.03)
        end

        closeNotification("expired")
    end)
    
    Cleanup:AddThread(timerThread)
    coroutine.resume(timerThread)

    return LMG2L["Frame_2"]
end
