-- ✅ GLOBAL STACK MANAGER
local NotificationStack = {
    Active = {},
    MaxNotifs = 5,
    Spacing = 15
}

function NotificationStack:Add(notifFrame, height)
    -- Tambah notif baru ke array (index 1 = terbaru)
    table.insert(self.Active, 1, {Frame = notifFrame, Height = height})
    
    -- ✅ Hapus notif terlama kalau melebihi max
    if #self.Active > self.MaxNotifs then
        local oldest = self.Active[#self.Active]
        if oldest and oldest.Frame then
            -- Fade out notif terlama
            TweenService:Create(oldest.Frame, TweenInfo.new(0.3), {
                Position = UDim2.fromScale(-0.5, oldest.Frame.Position.Y.Scale)
            }):Play()
            task.wait(0.3)
            oldest.Frame:Destroy()
        end
        table.remove(self.Active, #self.Active)
    end
    
    self:Reposition()
end

function NotificationStack:Remove(notifFrame)
    for i, notif in ipairs(self.Active) do
        if notif.Frame == notifFrame then
            table.remove(self.Active, i)
            break
        end
    end
    self:Reposition()
end

function NotificationStack:Reposition()
    local containerHeight = Container.AbsoluteSize.Y
    
    -- ✅ Loop dari terbaru (index 1, di bawah) ke terlama (index n, di atas)
    for i, notif in ipairs(self.Active) do
        if notif.Frame and notif.Frame.Parent then
            -- Hitung posisi Y: index 1 = 0, index 2 = height+spacing, dst
            local yOffset = 0
            for j = 1, i - 1 do
                yOffset = yOffset + self.Active[j].Height + self.Spacing
            end
            
            local yScale = yOffset / containerHeight
            
            TweenService:Create(notif.Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Position = UDim2.fromScale(0, yScale)
            }):Play()
        end
    end
end

local function CalculateMinHeight(text, width)
    local padding = 20
    local headerHeight = 35
    local progressHeight = 3
    local textTopPadding = 5
    local textBottomPadding = 10
    
    local textParams = Instance.new("GetTextBoundsParams")
    textParams.Text = text
    textParams.Font = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    textParams.Size = 14
    textParams.Width = width - (padding * 2)
    
    local wrappedSize = TextService:GetTextBoundsAsync(textParams)
    
    local minHeight = headerHeight + progressHeight + wrappedSize.Y + textTopPadding + textBottomPadding
    minHeight = math.max(minHeight, 85)
    
    return minHeight
end

