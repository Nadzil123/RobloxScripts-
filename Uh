                Size = UDim2.new(0, 30, 0, 30)
            }))
            hoverTween:Play()
        end
    end))

    Cleanup:AddConnection(LMG2L["TextButton_6"].MouseLeave:Connect(function()
        if not isClosing then
            local leaveTween = Cleanup:AddTween(TweenService:Create(LMG2L["TextButton_6"], TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(255, 60, 60),
                Size = UDim2.new(0, 28, 0, 28)
            }))
            leaveTween:Play()
        end
    end))

    if config.Text then
        LMG2L["NotificationText_7"].Text = config.Text
    end
    
    if config.Title then
        LMG2L["NotificationLabel_4"].Text = "  " .. config.Title
    end
    
    if config.BarColor then
        LMG2L["ProgressBar_12"].BackgroundColor3 = config.BarColor
    end
    
    local duration = config.Duration or 5
    
    if duration <= 0 then
        duration = 5
    end
    
    -- Remove oldest
    local allNotifs = {}
    for _, child in pairs(Container:GetChildren()) do
        if child:IsA("Frame") then
            table.insert(allNotifs, child)
        end
    end
    
    table.sort(allNotifs, function(a, b)
        return a.LayoutOrder > b.LayoutOrder
    end)
    
    while #allNotifs > MaxNotifications do
        local oldest = allNotifs[#allNotifs]
        local oldScale = oldest:FindFirstChildOfClass("UIScale")
        if oldScale then
            local removeTween = TweenService:Create(oldScale, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Scale = 0.7
            })
            removeTween:Play()
        end
        task.wait(0.3)
        
        if config.OnMaxExceeded then
            local removedData = {
                Reason = "max_exceeded",
                NotificationId = -1,
                Title = "Unknown",
                Text = "Unknown",
                CreatedAt = 0,
                ClosedAt = tick(),
                LifeTime = 0,
                WasManualClose = false,
                WasAutoClose = false,
                WasRemovedByLimit = true
            }
            task.spawn(function()
                pcall(config.OnMaxExceeded, removedData)
            end)
        end
        
        oldest:Destroy()
        table.remove(allNotifs, #allNotifs)
    end
    
    -- ✅ SMOOTH spawn animation
    task.wait(0.05)
    
    local spawnTime = 0.5
    
    LMG2L["Frame_2"].Position = UDim2.new(0, 50, 0, 0)
    
    local spawnScaleTween = Cleanup:AddTween(TweenService:Create(uiScale, TweenInfo.new(spawnTime, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Scale = 1
    }))
    spawnScaleTween:Play()
    
    local spawnSlideTween = Cleanup:AddTween(TweenService:Create(LMG2L["Frame_2"], TweenInfo.new(spawnTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 0.05
    }))
    spawnSlideTween:Play()
    
    task.wait(0.1)
    
    local shadowTween = Cleanup:AddTween(TweenService:Create(LMG2L["Shadow_9"], TweenInfo.new(0.3), {
        ImageTransparency = 0.5
    }))
    shadowTween:Play()
    
    local headerTween = Cleanup:AddTween(TweenService:Create(LMG2L["NotificationLabel_4"], TweenInfo.new(0.3), {
        TextTransparency = 0,
        BackgroundTransparency = 0
    }))
    headerTween:Play()
    
    task.wait(0.05)
    
    local closeTween = Cleanup:AddTween(TweenService:Create(LMG2L["TextButton_6"], TweenInfo.new(0.3), {
        TextTransparency = 0,
        BackgroundTransparency = 0
    }))
    closeTween:Play()
    
    task.wait(0.05)
    
    local progressContainerTween = Cleanup:AddTween(TweenService:Create(LMG2L["ProgressContainer_13"], TweenInfo.new(0.3), {
        BackgroundTransparency = 0
    }))
    progressContainerTween:Play()
    
    local progressBarTween = Cleanup:AddTween(TweenService:Create(LMG2L["ProgressBar_12"], TweenInfo.new(0.3), {
        BackgroundTransparency = 0
    }))
    progressBarTween:Play()
    
    task.wait(0.05)
    
    local textTween = Cleanup:AddTween(TweenService:Create(LMG2L["NotificationText_7"], TweenInfo.new(0.3), {
        TextTransparency = 0
    }))
    textTween:Play()

    -- Progress timer
    local timerThread = coroutine.create(function()
        local startTime = tick()

        while not isClosing do
            local elapsed = tick() - startTime
            local progress = 1 - (elapsed / duration)

            if progress <= 0 then
                LMG2L["ProgressBar_12"].Size = UDim2.new(0, 0, 1, 0)
                break
            end

            LMG2L["ProgressBar_12"].Size = UDim2.new(progress, 0, 1, 0)
            task.wait(0.03)
        end

        closeNotification("expired")
    end)
    
    Cleanup:AddThread(timerThread)
    coroutine.resume(timerThread)

    return LMG2L["Frame_2"]
end
