local SpamPreventionDelay = 0.1
local LastNotificationTime = 0

local ActiveNotifications = {}

local function CalculateMinHeight(text, width)
    local padding = 20
    local headerHeight = 35
    local progressHeight = 3
    local textTopPadding = 5
    local textBottomPadding = 10
    
    local textParams = Instance.new("GetTextBoundsParams")
    textParams.Text = text
    textParams.Font = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    textParams.Size = 14
    textParams.Width = width - (padding * 2)
    
    local wrappedSize = TextService:GetTextBoundsAsync(textParams)
    
    local minHeight = headerHeight + progressHeight + wrappedSize.Y + textTopPadding + textBottomPadding
    minHeight = math.max(minHeight, 85)
    
    return minHeight
end

local function RepositionAllNotifications(skipNotif, instant)
    local yOffset = 0
    local spacing = 15
    
    for i = #ActiveNotifications, 1, -1 do
        local notifData = ActiveNotifications[i]
        
        if notifData and notifData.Frame and notifData.Frame.Parent and notifData ~= skipNotif then
            -- ✅ Position from bottom: 1,1 = bottom right corner, offset up by yOffset
            local targetPos = UDim2.new(1, 0, 1, -(yOffset + notifData.Height))
            
            if instant then
                notifData.Frame.Position = targetPos
            else
                TweenService:Create(notifData.Frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = targetPos
                }):Play()
            end
        end
        
        if notifData and notifData.Height then
            yOffset = yOffset + notifData.Height + spacing
        end
    end
end

