local TweenService = game:GetService("TweenService")
local TextService = game:GetService("TextService")
local Players = game:GetService("Players")

local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")

local RootGui = playerGui:FindFirstChild("NotificationRoot")
if not RootGui then
    RootGui = Instance.new("ScreenGui")
    RootGui.Name = "NotificationRoot"
    RootGui.ResetOnSpawn = false
    RootGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    RootGui.Parent = playerGui
end

local Container = RootGui:FindFirstChild("Container")
if not Container then
    Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.AnchorPoint = Vector2.new(1, 1)
    Container.Position = UDim2.new(1, -20, 1, -20)
    Container.Size = UDim2.new(0, 280, 0, 600)
    Container.BackgroundTransparency = 1
    Container.Parent = RootGui

    local listLayout = Instance.new("UIListLayout")
    listLayout.Name = "ListLayout"
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 10)
    listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    listLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    listLayout.Parent = Container
end

local NotificationCount = 0
local MaxNotifications = 5
local SpamPreventionDelay = 0.1
local LastNotificationTime = 0

local function CalculateMinHeight(text, width)
    local textParams = Instance.new("GetTextBoundsParams")
    textParams.Text = text
    textParams.Font = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    textParams.Size = 14
    textParams.Width = width - 40
    local s = TextService:GetTextBoundsAsync(textParams)
    return math.max(35 + 3 + s.Y + 15, 85)
end

return function(config)
    config = config or {}

    local now = tick()
    if now - LastNotificationTime < SpamPreventionDelay then
        task.wait(SpamPreventionDelay - (now - LastNotificationTime))
    end
    LastNotificationTime = tick()

    local text   = config.Text or "Notification"
    local title  = config.Title or "Notification"
    local width  = config.Width or 260
    local height = config.Height and math.max(config.Height, CalculateMinHeight(text, width)) or CalculateMinHeight(text, width)
    local dur    = math.max(config.Duration or 5, 0.1)

    NotificationCount += 1

    local isClosing = false

    -- ===== CLEANUP =====
    local Tweens, Conns, Threads = {}, {}, {}
    local function addTween(t)  table.insert(Tweens, t);   return t end
    local function addConn(c)   table.insert(Conns, c);    return c end
    local function addThread(t) table.insert(Threads, t);  return t end
    local function cleanAll()
        for _, t in ipairs(Tweens)   do pcall(function() t:Cancel(); t:Destroy() end) end
        for _, c in ipairs(Conns)    do if c.Connected then pcall(function() c:Disconnect() end) end end
        for _, th in ipairs(Threads) do if coroutine.status(th)=="suspended" then pcall(function() coroutine.close(th) end) end end
        table.clear(Tweens); table.clear(Conns); table.clear(Threads)
    end

    -- ===== NOTIF DATA =====
    local data = { Id = NotificationCount, Title = title, Text = text, CreatedAt = tick() }

    -- ===== WRAPPER =====
    -- UIListLayout baca size Wrapper
    -- Saat spawn: tween 0 → height  → notif lain smooth naik
    -- Saat close: tween height → 0  → notif lain smooth turun
    local Wrapper = Instance.new("Frame")
    Wrapper.Name            = "Wrapper_" .. NotificationCount
    Wrapper.BorderSizePixel = 0
    Wrapper.BackgroundTransparency = 1
    Wrapper.Size            = UDim2.new(0, width, 0, 0) -- ← start 0!
    Wrapper.ClipsDescendants = true -- ← clip Frame saat slide
    Wrapper.LayoutOrder     = -NotificationCount
    Wrapper.Parent          = Container

    -- ===== INNER FRAME (yang slide kanan) =====
    local Frame = Instance.new("Frame")
    Frame.BorderSizePixel    = 0
    Frame.BackgroundColor3   = Color3.fromRGB(35, 35, 40)
    Frame.BackgroundTransparency = 1
    Frame.Size               = UDim2.new(1, 0, 0, height)
    Frame.Position           = UDim2.new(1, 60, 0, 0) -- ← start offscreen kanan
    Frame.ClipsDescendants   = true
    Frame.Parent             = Wrapper
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

    local Shadow = Instance.new("ImageLabel", Frame)
    Shadow.BackgroundTransparency = 1
    Shadow.Size           = UDim2.new(1, 30, 1, 30)
    Shadow.Position       = UDim2.new(0, -15, 0, -15)
    Shadow.Image          = "rbxassetid://6014261993"
    Shadow.ImageColor3    = Color3.fromRGB(0, 0, 0)
    Shadow.ImageTransparency = 1
    Shadow.ScaleType      = Enum.ScaleType.Slice
    Shadow.SliceCenter    = Rect.new(49, 49, 450, 450)
    Shadow.ZIndex         = -1

    local Header = Instance.new("TextLabel", Frame)
    Header.BorderSizePixel    = 0
    Header.BackgroundColor3   = Color3.fromRGB(45, 45, 50)
    Header.BackgroundTransparency = 1
    Header.TextColor3         = Color3.fromRGB(255, 255, 255)
    Header.TextTransparency   = 1
    Header.TextSize           = 16
    Header.FontFace           = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
    Header.TextXAlignment     = Enum.TextXAlignment.Left
    Header.Text               = "  " .. title
    Header.Size               = UDim2.new(1, 0, 0, 35)
    Header.Position           = UDim2.new(0, 0, 0, 0)
    Instance.new("UICorner", Header).CornerRadius = UDim.new(0, 10)

    local CloseBtn = Instance.new("TextButton", Header)
    CloseBtn.BorderSizePixel    = 0
    CloseBtn.BackgroundColor3   = Color3.fromRGB(255, 60, 60)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.TextColor3         = Color3.fromRGB(255, 255, 255)
    CloseBtn.TextTransparency   = 1
    CloseBtn.TextSize           = 16
    CloseBtn.FontFace           = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
    CloseBtn.Text               = "×"
    CloseBtn.Size               = UDim2.new(0, 28, 0, 28)
    CloseBtn.AnchorPoint        = Vector2.new(1, 0.5)
    CloseBtn.Position           = UDim2.new(1, -8, 0.5, 0)
    Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(1, 0)

    local ProgBG = Instance.new("Frame", Frame)
    ProgBG.BorderSizePixel    = 0
    ProgBG.BackgroundColor3   = Color3.fromRGB(60, 60, 65)
    ProgBG.BackgroundTransparency = 1
    ProgBG.Size               = UDim2.new(1, 0, 0, 3)
    ProgBG.Position           = UDim2.new(0, 0, 0, 35)
    ProgBG.ClipsDescendants   = true

    local ProgBar = Instance.new("Frame", ProgBG)
    ProgBar.BorderSizePixel    = 0
    ProgBar.BackgroundColor3   = config.BarColor or Color3.fromRGB(50, 200, 100)
    ProgBar.BackgroundTransparency = 1
    ProgBar.Size               = UDim2.new(1, 0, 1, 0)

    local Body = Instance.new("TextLabel", Frame)
    Body.TextWrapped          = true
    Body.BorderSizePixel      = 0
    Body.BackgroundTransparency = 1
    Body.TextColor3           = Color3.fromRGB(220, 220, 220)
    Body.TextTransparency     = 1
    Body.TextSize             = 14
    Body.FontFace             = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    Body.TextXAlignment       = Enum.TextXAlignment.Left
    Body.TextYAlignment       = Enum.TextYAlignment.Top
    Body.Text                 = text
    Body.Size                 = UDim2.new(1, -40, 1, -48)
    Body.Position             = UDim2.new(0, 20, 0, 43)
    Instance.new("UICorner", Body).CornerRadius = UDim.new(0, 6)

    -- ===== CLOSE FUNCTION =====
    -- Berlaku untuk: user click X, expired, max_exceeded
    local function closeNotification(reason)
        if isClosing then return end
        isClosing = true

        local callbackData = {
            Reason          = reason,
            NotificationId  = data.Id,
            Title           = data.Title,
            Text            = data.Text,
            CreatedAt       = data.CreatedAt,
            ClosedAt        = tick(),
            LifeTime        = tick() - data.CreatedAt,
            WasManualClose  = reason == "user",
            WasAutoClose    = reason == "expired",
            WasRemovedByLimit = reason == "max_exceeded"
        }

        -- ✅ STEP 1: Frame slide kanan + fade
        -- Sama untuk semua trigger (user, expired, max_exceeded)
        addTween(TweenService:Create(Frame,
            TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 60, 0, 0),
                BackgroundTransparency = 1
            })):Play()

        for _, child in ipairs(Frame:GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                addTween(TweenService:Create(child, TweenInfo.new(0.3), {
                    TextTransparency = 1, BackgroundTransparency = 1
                })):Play()
            elseif child:IsA("Frame") then
                addTween(TweenService:Create(child, TweenInfo.new(0.3), {
                    BackgroundTransparency = 1
                })):Play()
            elseif child:IsA("ImageLabel") then
                addTween(TweenService:Create(child, TweenInfo.new(0.3), {
                    ImageTransparency = 1
                })):Play()
            end
        end

        task.wait(0.3)

        -- ✅ STEP 2: Wrapper shrink height → 0
        -- UIListLayout otomatis smooth geser notif di atas turun
        addTween(TweenService:Create(Wrapper,
            TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, width, 0, 0)
            })):Play()

        task.wait(0.35)

        cleanAll()
        if Wrapper and Wrapper.Parent then Wrapper:Destroy() end

        task.spawn(function()
            if reason == "user"         and config.OnUserClose   then pcall(config.OnUserClose,   callbackData) end
            if reason == "expired"      and config.OnExpire       then pcall(config.OnExpire,       callbackData) end
            if reason == "max_exceeded" and config.OnMaxExceeded  then pcall(config.OnMaxExceeded,  callbackData) end
            if config.OnClose then pcall(config.OnClose, callbackData) end
        end)
    end

    -- ===== CONNECTIONS =====
    addConn(CloseBtn.MouseButton1Click:Connect(function()
        closeNotification("user")
    end))

    addConn(CloseBtn.MouseEnter:Connect(function()
        if not isClosing then
            addTween(TweenService:Create(CloseBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(255, 80, 80),
                Size = UDim2.new(0, 30, 0, 30)
            })):Play()
        end
    end))

    addConn(CloseBtn.MouseLeave:Connect(function()
        if not isClosing then
            addTween(TweenService:Create(CloseBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(255, 60, 60),
                Size = UDim2.new(0, 28, 0, 28)
            })):Play()
        end
    end))

    -- ===== MAX NOTIFICATIONS =====
    local all = {}
    for _, c in pairs(Container:GetChildren()) do
        if c:IsA("Frame") and c.Name ~= "Container" then
            table.insert(all, c)
        end
    end
    table.sort(all, function(a, b) return a.LayoutOrder > b.LayoutOrder end)
    while #all > MaxNotifications do
        local oldest = all[#all]
        if oldest and oldest.Parent then oldest:Destroy() end
        table.remove(all, #all)
    end

    -- ===== SPAWN ANIMATION =====
    task.wait(0.05)

    -- Wrapper grow 0 → height (notif lain naik smooth)
    addTween(TweenService:Create(Wrapper,
        TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, width, 0, height)
        })):Play()

    -- Frame slide in dari kanan
    addTween(TweenService:Create(Frame,
        TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 0.05
        })):Play()

    task.wait(0.1)

    addTween(TweenService:Create(Shadow,  TweenInfo.new(0.3), { ImageTransparency = 0.5 })):Play()
    addTween(TweenService:Create(Header,  TweenInfo.new(0.3), { TextTransparency = 0, BackgroundTransparency = 0 })):Play()
    task.wait(0.05)
    addTween(TweenService:Create(CloseBtn, TweenInfo.new(0.3), { TextTransparency = 0, BackgroundTransparency = 0 })):Play()
    task.wait(0.05)
    addTween(TweenService:Create(ProgBG,  TweenInfo.new(0.3), { BackgroundTransparency = 0 })):Play()
    addTween(TweenService:Create(ProgBar, TweenInfo.new(0.3), { BackgroundTransparency = 0 })):Play()
    task.wait(0.05)
    addTween(TweenService:Create(Body,    TweenInfo.new(0.3), { TextTransparency = 0 })):Play()

    -- ===== PROGRESS + AUTO EXPIRE =====
    local timerThread = coroutine.create(function()
        local startTime = tick()
        while not isClosing do
            local progress = 1 - ((tick() - startTime) / dur)
            if progress <= 0 then
                ProgBar.Size = UDim2.new(0, 0, 1, 0)
                break
            end
            ProgBar.Size = UDim2.new(progress, 0, 1, 0)
            task.wait(0.03)
        end
        -- ✅ Expired = closeNotification("expired") = SLIDE KANAN juga!
        closeNotification("expired")
    end)
    addThread(timerThread)
    coroutine.resume(timerThread)

    return Wrapper
end
