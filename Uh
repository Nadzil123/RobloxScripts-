local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

-- ✅ Notification Stack Manager
local NotificationStack = {
    ActiveNotifications = {},
    Spacing = 10,
    StartY = -20
}

function NotificationStack:GetNextPosition()
    local totalHeight = self.StartY
    for _, notif in ipairs(self.ActiveNotifications) do
        if notif and notif.Frame and notif.Frame.Parent then
            totalHeight = totalHeight - notif.Frame.Size.Y.Offset - self.Spacing
        end
    end
    return totalHeight
end

function NotificationStack:Add(notification)
    table.insert(self.ActiveNotifications, notification)
    self:UpdatePositions()
end

function NotificationStack:Remove(notification)
    for i, notif in ipairs(self.ActiveNotifications) do
        if notif == notification then
            table.remove(self.ActiveNotifications, i)
            break
        end
    end
    self:UpdatePositions()
end

function NotificationStack:UpdatePositions()
    local yOffset = self.StartY
    for _, notif in ipairs(self.ActiveNotifications) do
        if notif and notif.Frame and notif.Frame.Parent then
            local targetPos = UDim2.new(1, -20, 1, yOffset)
            TweenService:Create(notif.Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = targetPos
            }):Play()
            yOffset = yOffset - notif.Frame.Size.Y.Offset - self.Spacing
        end
    end
end

-- ✅ Main Notification Function
return function(config)
    config = config or {}
    
    -- Default config
    local settings = {
        Duration = config.Duration or 5,
        Text = config.Text or "This is an example notification with improved UI design.",
        Title = config.Title or "Notification",
        Width = config.Width or 320,
        Height = config.Height or 130,
        BarColor = config.BarColor or Color3.fromRGB(50, 200, 100),
        OnClose = config.OnClose
    }
    
    local LMG2L = {}
    local isClosing = false
    
    -- Create ScreenGui
    LMG2L["ScreenGui"] = Instance.new("ScreenGui", Players.LocalPlayer:WaitForChild("PlayerGui"))
    LMG2L["ScreenGui"]["ZIndexBehavior"] = Enum.ZIndexBehavior.Sibling
    LMG2L["ScreenGui"]["ResetOnSpawn"] = false
    
    -- Main Frame
    LMG2L["Frame"] = Instance.new("Frame", LMG2L["ScreenGui"])
