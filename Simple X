function switchToTab(index)
    if not tabs[index] then return end
    
    if tabs[activeTabIndex] then
        tabs[activeTabIndex].content = CodeBox.Text
    end
    
    activeTabIndex = index
    CodeBox.Text = tabs[index].content
    
    for i, child in ipairs(TabContainer:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("Tab") then
            local tabNum = tonumber(child.Name:match("%d+"))
            if tabNum == index then
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            else
                child.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
            end
        end
    end
end

function removeTab(index)
    if #tabs <= 1 then 
        print("Cannot remove last tab!")
        return 
    end
    
    print("Removing tab", index)
    
    table.remove(tabs, index)
    
    local tabFrame = TabContainer:FindFirstChild("Tab" .. index)
    if tabFrame then
        tabFrame:Destroy()
    end
    
    for i, child in ipairs(TabContainer:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("Tab") then
            local oldNum = tonumber(child.Name:match("%d+"))
            if oldNum > index then
                child.Name = "Tab" .. (oldNum - 1)
            end
        end
    end
    
    if activeTabIndex >= index then
        activeTabIndex = math.max(1, activeTabIndex - 1)
    end
    switchToTab(activeTabIndex)
    
    TabContainer.CanvasSize = UDim2.new(0, TabListLayout.AbsoluteContentSize.X, 0, 24)
end

